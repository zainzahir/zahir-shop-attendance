# Local client — copy your Supabase connection string here
# NEVER commit this file to Git (it is in .gitignore)
#
# 1. Copy this file:   copy .env.example .env
# 2. Open .env and replace <YOUR-PASSWORD> with your real Supabase DB password
# 3. Get the password from: supabase.com → Project Settings → Database → Connection string → URI

DATABASE_URL=postgresql://postgres.<YOUR-PROJECT-REF>:<YOUR-PASSWORD>@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
